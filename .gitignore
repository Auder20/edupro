```gitignore
# Dependencies
node_modules/

# Build outputs
dist/
build/
*.js.map
*.tsbuildinfo

# Environment
.env
.env.local
*.env.*

# Editors
.vscode/
.idea/
*.swp
*.swo

# Logs and temp files
*.log
*.tmp

# Coverage
coverage/
htmlcov/
.coverage

# Python (if applicable)
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
.venv/
pip-log.txt
pip-delete-this-directory.txt
.tox/
.coverage*
.nox/
*.cover
*.log
.pytest_cache/
.mypy_cache/
.hypothesis/

# Compiled and binary
*.o
*.obj
*.exe
*.dll
*.so
*.a
*.out

# System files
.DS_Store
Thumbs.db

# Compressed files
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst
```
